GOOGLE_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=...
GROQ_MODEL=openai/gpt-oss-120b

DYNAMODB_ANALYSIS_TABLE_NAME=...
SQS_QUEUE_URL=...

AWS_REGION=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=...
ANALYSIS_USER_ID=...

# --- SUPABASE ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_JWT_SECRET=...

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=...

# --- AWS X-RAY ---
# In AWS Lambda, also enable "Active tracing" on the function.
AWS_XRAY_CONTEXT_MISSING=LOG_ERROR
XRAY_SERVICE_NAME=cv-enhancer
XRAY_DISABLED=false

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# --- APP CONFIG ---
ENV=development
PORT=8000

# --- LOCAL DEV ---
# If set to true, the API will run analysis jobs in-process (no SQS worker needed).
IN_PROCESS_WORKER=0