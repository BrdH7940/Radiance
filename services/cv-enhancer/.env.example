# --- CORS ---
# Comma-separated list of allowed origins. No wildcards — required because
# allow_credentials=True is incompatible with wildcard origins per the CORS spec.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com

# --- APP CONFIG ---
ENV=development
PORT=8000