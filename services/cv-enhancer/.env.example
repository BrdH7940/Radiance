GOOGLE_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

DYNAMODB_ANALYSIS_TABLE_NAME=...
SQS_QUEUE_URL=...

AWS_REGION=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=...
ANALYSIS_USER_ID=...

# --- SUPABASE ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
